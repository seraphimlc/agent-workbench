{
  "name": "agent-workbench",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.26.1",
  "pnpm": {
    "ignoredBuiltDependencies": [
      "esbuild"
    ],
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run --maxWorkers=1",
    "test:watch": "vitest",
    "lint": "eslint . --max-warnings=0",
    "demo:web": "pnpm --filter @agent-workbench/web-console dev",
    "smoke:runtime": "node --conditions=development --import tsx scripts/runtime-smoke.ts",
    "smoke:web-real": "node --conditions=development --import tsx scripts/web-console-real-smoke.ts"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "26.1.1",
    "eslint": "10.7.0",
    "globals": "17.7.0",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}
